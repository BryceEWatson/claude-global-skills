{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "finding_id",
    "retro_date",
    "retro_path",
    "project",
    "category",
    "claim",
    "confidence",
    "evidence_supporting",
    "evidence_contradicting",
    "proposed_action",
    "target_date",
    "follow_up_status",
    "appended_at",
    "appended_by"
  ],
  "properties": {
    "finding_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{3}$"
    },
    "retro_date": {
      "type": "string",
      "format": "date"
    },
    "retro_path": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "claim": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "evidence_summary": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_supporting": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_contradicting": {
      "type": "integer",
      "minimum": 0
    },
    "proposed_action": {
      "type": "string"
    },
    "target_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "follow_up_status": {
      "type": "string",
      "enum": [
        "pending",
        "in-progress",
        "shipped",
        "abandoned",
        "superseded",
        "cancelled"
      ]
    },
    "follow_up_notes": {
      "type": "string"
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    },
    "appended_at": {
      "type": "string",
      "format": "date-time"
    },
    "appended_by": {
      "type": "string"
    }
  }
}
